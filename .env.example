# Copy this file to .env and fill in only the providers you want to test.

OPENAI_API_KEY=
DEEPSEEK_API_KEY=
TOGETHER_API_KEY=
GEMINI_API_KEY=
# GOOGLE_API_KEY=  # optional alternative name for Gemini

# Optional comma-separated model lists
OPENAI_MODELS=gpt-4.1-mini,gpt-5.4
DEEPSEEK_MODELS=deepseek-chat
TOGETHER_MODELS=moonshotai/Kimi-K2.5,meta-llama/Llama-3.3-70B-Instruct-Turbo,deepseek-ai/DeepSeek-V3.1,deepseek-ai/DeepSeek-R1
GEMINI_MODELS=gemini-3.1-pro-preview,gemini-2.5-pro,gemini-2.5-flash
